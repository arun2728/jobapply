# Optional: copy to .env if you prefer keeping secrets out of jobapply.toml.
# `jobapply.toml` can also reference these via api_key = "env:VAR_NAME".

# Google Gemini (langchain-google-genai)
GOOGLE_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local; api_key usually empty)
OLLAMA_BASE_URL=http://127.0.0.1:11434
