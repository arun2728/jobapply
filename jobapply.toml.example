# Sample jobapply.toml.
# Copy this to `jobapply.toml` and fill in your provider details, or run
# `jobapply init` for an interactive setup. Both flows produce the same file.
#
# Secrets in this file are convenient but sensitive. For shared repos prefer
# the `env:VAR_NAME` indirection (or a real .env) shown below.

# Active LLM provider: "gemini" | "anthropic" | "openai" | "ollama" | "cloudflare".
provider = "gemini"

# Optional: override the active provider's model. If omitted, the provider's
# own [providers.<name>].model is used.
# model = "gemini-2.0-flash"

min_fit = 0.35
results_wanted = 30
hours_old = 720
concurrency = 1
sites = ["indeed", "linkedin", "google"]
profile_path = "profile.md"
output_dir = "output"
# Path to the dedupe ledger. Default: `./.jobapply/ledger.db` (workspace-local
# so each project keeps its own history). Use an absolute path or `~/...` if
# you want a shared ledger across projects. Relative paths are resolved
# against the workspace root.
# ledger_path = "ledger.db"


# --- Provider connection details -------------------------------------------
# Each block is optional; only the active provider must be filled in.
# `api_key` accepts either a literal value or `env:VAR_NAME` to defer the
# secret to the environment at runtime.

[providers.gemini]
# api_key = "env:GOOGLE_API_KEY"
# api_key = "AIza..."
model = "gemini-2.0-flash"

[providers.anthropic]
# api_key = "env:ANTHROPIC_API_KEY"
# api_key = "sk-ant-..."
model = "claude-3-5-haiku-latest"

[providers.openai]
# api_key = "env:OPENAI_API_KEY"
# api_key = "sk-..."
# Use `base_url` for OpenAI-compatible gateways (Azure, Together, Groq, etc).
# base_url = "https://api.openai.com/v1"
model = "gpt-4o-mini"

[providers.ollama]
# Ollama is local and usually requires no api_key.
# api_key = ""
base_url = "http://127.0.0.1:11434"
model = "llama3.1"

[providers.cloudflare]
# Cloudflare Workers AI exposes an OpenAI-compatible /v1 endpoint scoped to
# your account. Create an API token with the "Workers AI" permission at
# https://dash.cloudflare.com/profile/api-tokens, and grab your account id
# from the Workers & Pages overview page.
# api_key = "env:CLOUDFLARE_API_TOKEN"
# api_key = "v1.0-..."
# account_id = "env:CLOUDFLARE_ACCOUNT_ID"
# account_id = "abcdef0123456789abcdef0123456789"
#
# Two routing modes:
#   1. Direct Workers AI (default): leave `gateway_id` unset. Only native
#      `@cf/...` models work — pick one from
#      https://developers.cloudflare.com/workers-ai/models/.
#   2. AI Gateway (BYOK): set `gateway_id` to your gateway slug. Then
#      `model` uses the `provider/model` form (e.g. `openai/gpt-5`,
#      `anthropic/claude-3-5-sonnet`, or
#      `workers-ai/@cf/meta/llama-3.3-70b-instruct-fp8-fast`). Configure the
#      provider's API key in the gateway's "Stored Keys" tab first:
#      https://developers.cloudflare.com/ai-gateway/configuration/bring-your-own-keys/
# gateway_id = "env:CLOUDFLARE_AI_GATEWAY_ID"
# gateway_id = "my-gateway"
model = "@cf/openai/gpt-oss-120b"


# --- LaTeX → PDF compile service -------------------------------------------
# By default jobapply POSTs your tailored .tex to a hosted latex-on-http
# instance and writes the returned PDF — no local TeX install required.
# Local engines (`tectonic`, `pdflatex`) are still used as fallbacks if
# the API is unreachable or disabled.
#
# To self-host (recommended for privacy / reliability):
#   docker run -d -p 8080:8080 yotools/latex-on-http
# then set `url = "http://localhost:8080/builds/sync"` below.
#
# Each setting can be overridden at runtime with an env var:
#   JOBAPPLY_LATEX_API_URL, JOBAPPLY_LATEX_API_DISABLE,
#   JOBAPPLY_LATEX_API_COMPILER, JOBAPPLY_LATEX_API_TIMEOUT

[latex_api]
enabled = true
url = "https://latex.ytotech.com/builds/sync"
# Engine the API runs: pdflatex | xelatex | lualatex | latexmk
compiler = "pdflatex"
timeout = 120.0
