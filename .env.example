# Optional: copy to .env if you prefer keeping secrets out of jobapply.toml.
# `jobapply.toml` can also reference these via api_key = "env:VAR_NAME".

# Google Gemini (langchain-google-genai)
GOOGLE_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local; api_key usually empty)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Cloudflare Workers AI (OpenAI-compatible). Create an API token with the
# "Workers AI" permission at https://dash.cloudflare.com/profile/api-tokens.
# Account id is on the Workers & Pages overview page.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Optional: AI Gateway slug. Set this (and configure BYOK keys in the gateway)
# to call models like openai/gpt-5 or anthropic/claude-... — otherwise only
# native @cf/... Workers AI models are reachable.
# CLOUDFLARE_AI_GATEWAY_ID=
